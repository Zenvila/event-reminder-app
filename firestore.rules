rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each authenticated user can only access their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Optional subcollection for user-owned events synced to cloud.
      match /events/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}